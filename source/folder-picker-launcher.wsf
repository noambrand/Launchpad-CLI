<job>
<script language="JScript">
// ClaudeCode Launchpad CLI - Folder Picker & Launcher
// Invokes the HTA picker (model radios, flag chips, startup slash commands),
// waits for it to close, and launches claudecode-launchpad.bat if (and only
// if) the user clicked Launch. Cancel terminates without spawning the bat.

var wshShell = new ActiveXObject("WScript.Shell");
var fso = new ActiveXObject("Scripting.FileSystemObject");

var scriptDir = fso.GetParentFolderName(WScript.ScriptFullName);
var kivunDir = wshShell.ExpandEnvironmentStrings("%LOCALAPPDATA%") + "\\Kivun";
var workdirFile = kivunDir + "\\kivun-workdir.txt";
var htaPath = scriptDir + "\\folder-picker.hta";

if (!fso.FolderExists(kivunDir)) {
    fso.CreateFolder(kivunDir);
}

// Stale workdir from a previous cancelled run would falsely trigger a
// launch — clear it before mshta gets the chance to write a fresh one.
try { if (fso.FileExists(workdirFile)) fso.DeleteFile(workdirFile); } catch (e) {}

if (!fso.FileExists(htaPath)) {
    wshShell.Popup(
        "folder-picker.hta is missing from " + scriptDir + ".\r\n\r\n" +
        "Try reinstalling ClaudeCode Launchpad CLI.",
        0, "ClaudeCode Launchpad CLI", 16  // vbCritical
    );
    WScript.Quit(1);
}

// 1 = visible window, true = wait for mshta to exit. The HTA writes
// kivun-workdir.txt + kivun-claude-flags.txt + kivun-claude-startcmd.txt
// on Launch, nothing on Cancel.
wshShell.Run("mshta.exe \"" + htaPath + "\"", 1, true);

// Cancel = no kivun-workdir.txt was written. Terminate cleanly without
// launching the .bat (otherwise launcher would silently fall back to
// %USERPROFILE%, which from the user's POV looks like Cancel didn't work).
if (!fso.FileExists(workdirFile)) {
    WScript.Quit(0);
}

// Launch claudecode-launchpad.bat with READFILE argument so it picks
// the path from kivun-workdir.txt. Window style 0 = hidden cmd window
// (Windows Terminal opens its own visible window).
wshShell.Run("\"" + scriptDir + "\\claudecode-launchpad.bat\" \"READFILE\"", 0, false);
</script>
</job>
